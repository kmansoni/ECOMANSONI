# G0DM0D3 API — Environment Variables

# REQUIRED: OpenRouter API key for multi-model queries
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: API authentication
# Single key or comma-separated for multiple keys
# If not set, API is open (no auth required)
GODMODE_API_KEY=your-secret-api-key
# GODMODE_API_KEYS=key1,key2,key3

# OPTIONAL: Server port (default: 3077)
PORT=3077
