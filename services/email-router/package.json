{
  "name": "@mansoni/email-router",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade email routing service with queue management, templating, bounce processing, and multi-tenant support",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/scripts/migrate.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^4.21.1",
    "bullmq": "^5.25.6",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "jose": "^5.9.6",
    "mjml": "^4.15.3",
    "handlebars": "^4.7.8",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "uuid": "^10.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.17.6",
    "pino-pretty": "^13.0.0",
    "vitest": "^2.1.5",
    "tsx": "^4.19.2",
    "eslint": "^9.14.0",
    "prettier": "^3.4.1",
    "@vitest/coverage-v8": "^2.1.5"
  }
}
