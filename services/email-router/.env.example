# =============================================================================
# Email Router — Environment Configuration
# =============================================================================
# Copy to .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://email:email_pass@localhost:5432/email_platform
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (used by BullMQ for job queues)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Supabase JWT Authentication
# -----------------------------------------------------------------------------
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWKS_URL=https://your-project.supabase.co/.well-known/jwks.json

# -----------------------------------------------------------------------------
# SMTP Configuration
# CRITICAL: provider=smtp ensures all mail flows through Postfix + OpenDKIM milter.
# Using provider=sendmail bypasses the milter pipeline — no DKIM signing.
# SMTP_HOST must be the local Postfix submission port (127.0.0.1:587).
# -----------------------------------------------------------------------------
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Email Defaults
# CRITICAL: Must match the domain with valid SPF/DKIM/DMARC DNS records.
# Using noreply@example.com causes SPF hardfail and immediate spam/rejection.
# -----------------------------------------------------------------------------
DEFAULT_FROM_EMAIL=noreply@mansoni.ru
DEFAULT_FROM_NAME=Mansoni Platform

# -----------------------------------------------------------------------------
# Mail Domain
# Used in Message-ID generation: <uuid@MAIL_DOMAIN> (RFC 2822 §3.6.4).
# Must match the sending domain (same as DEFAULT_FROM_EMAIL domain).
# A Message-ID of <uuid@127.0.0.1> signals spam to Gmail/iCloud.
# -----------------------------------------------------------------------------
MAIL_DOMAIN=mansoni.ru

# -----------------------------------------------------------------------------
# Unsubscribe Base URL (RFC 8058 One-Click Unsubscribe)
# Required by Gmail for senders >5000 messages/day (since Feb 2024).
# Must point to your unsubscribe handler: GET /unsubscribe?mid=<messageId>
# -----------------------------------------------------------------------------
UNSUBSCRIBE_BASE_URL=https://mansoni.ru

# -----------------------------------------------------------------------------
# IP Warmup Configuration
# New sending IPs have no reputation with Gmail/iCloud.
# Sending at full volume from day 1 causes immediate blacklisting.
#
# IP_LAUNCH_DATE: ISO 8601 date when the sending IP first sent mail.
# WARMUP_ENABLED: Set to false only after warmup period (>30 days) is complete.
#
# Warmup schedule enforced by WarmupRateLimiter:
#   Days  1-3:    50/day
#   Days  4-7:   200/day
#   Days  8-14:  500/day
#   Days 15-21: 1000/day
#   Days 22-30: 2000/day
#   Day  31+:   disabled (normal limits apply)
# -----------------------------------------------------------------------------
IP_LAUNCH_DATE=2026-03-26
WARMUP_ENABLED=true

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_TENANT_PER_MINUTE=60
RATE_LIMIT_BULK_PER_HOUR=1000

# -----------------------------------------------------------------------------
# Circuit Breaker (for SMTP connection failures)
# -----------------------------------------------------------------------------
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for sensitive payloads)
# Generate: openssl rand -base64 32
# WARNING: Changing this key will make all existing encrypted data unreadable.
#          Rotate with a migration that re-encrypts with the new key.
# -----------------------------------------------------------------------------
EMAIL_ENCRYPTION_KEY=base64-encoded-32-byte-key

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# -----------------------------------------------------------------------------
# Bounce Webhook Authentication (КРИТ-5)
# HMAC-SHA256 shared secret for POST /email/webhooks/bounce.
# Must match the secret configured in Postfix milter / rspamd / ESP.
# Generate with: openssl rand -hex 32
#
# REQUIRED in production (NODE_ENV=production) — startup fails if empty.
# Without this, any actor can forge bounce notifications and add legitimate
# addresses to the suppression list (DoS against your email delivery).
# -----------------------------------------------------------------------------
BOUNCE_WEBHOOK_SECRET=

# =============================================================================
# DNS Records Required for Deliverability (configure in your DNS panel)
# =============================================================================
# These are NOT env variables — they are DNS records that must exist BEFORE
# you send any email. Without them, Gmail/iCloud will reject or spam-classify
# your messages regardless of server configuration.
#
# 1. PTR Record (Reverse DNS) — REQUIRED by Gmail (550 5.7.25) and iCloud (421 TSS04)
#    Set in your VPS/hosting panel (e.g., Selectel/Timeweb → IP Settings → PTR):
#    155.212.245.89  →  mail.mansoni.ru
#    Then verify: dig -x 155.212.245.89 +short
#
# 2. SPF Record — authorize your sending IP:
#    mansoni.ru. IN TXT "v=spf1 ip4:155.212.245.89 mx ~all"
#    Verify: dig TXT mansoni.ru | grep spf
#
# 3. DKIM — sign outgoing mail (Postfix + OpenDKIM):
#    Generate: opendkim-genkey -s mail -d mansoni.ru -b 2048
#    Add to DNS:
#    mail._domainkey.mansoni.ru. IN TXT "v=DKIM1; k=rsa; p=<YOUR_PUBLIC_KEY>"
#    Verify: dig TXT mail._domainkey.mansoni.ru
#
# 4. DMARC — policy alignment + reporting:
#    Start with p=none for monitoring, then escalate to p=quarantine/p=reject.
#    _dmarc.mansoni.ru. IN TXT "v=DMARC1; p=none; rua=mailto:dmarc@mansoni.ru"
#    After 2 weeks of clean reports → change to p=quarantine
#    After 4 weeks → change to p=reject
#    Verify: dig TXT _dmarc.mansoni.ru
#
# 5. Blacklist check (before first send and monthly):
#    dig +short 89.245.212.155.zen.spamhaus.org  # empty = not listed
#    dig +short 89.245.212.155.bl.spamcop.net    # empty = not listed
#
# 6. Register with Postmaster Tools:
#    Google: https://postmaster.google.com  (add mansoni.ru, verify via DNS TXT)
#    Apple:  https://postmaster.apple.com   (add mansoni.ru, verify domain)
# =============================================================================
