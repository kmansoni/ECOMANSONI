# Required
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
ACCESS_TOKEN_SECRET=<strong-random-secret>

# Network
AUTH_SERVICE_PORT=8087
PHONE_AUTH_INTERNAL_URL=

# OTP behavior
OTP_MAX_ATTEMPTS=5
OTP_VALIDITY_SEC=300
SMS_STUB=false

# OTP start endpoint rate limiting (sliding window)
OTP_RL_IP_MAX=10
OTP_RL_PHONE_MAX=5
OTP_RL_WINDOW_MS=60000

# Security: trust X-Forwarded-For only from these direct proxy IPs
# Comma-separated list, for example:
# AUTH_TRUSTED_PROXIES=127.0.0.1,10.0.0.10
AUTH_TRUSTED_PROXIES=
