# Supabase configuration (copy from main .env)
VITE_SUPABASE_URL=your_supabase_url

# Preferred key used by the main Mansoni app
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Backward-compatible fallback if publishable key is not used yet
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: custom API URL if using separate backend
# VITE_MUSIC_API_URL=http://localhost:3080
