# Frontend runtime (Vite)
# Copy to .env.local (recommended) or .env and fill in values.

# ===== Build marker (deploy verification) =====
# Рекомендуется задавать в CI/CD:
#   VITE_APP_COMMIT_SHA=$(git rev-parse --short HEAD)
#   VITE_APP_BUILD_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
VITE_APP_NAME="ECOMANSONI"
VITE_APP_VERSION="0.0.0"
VITE_APP_COMMIT_SHA="dev"
VITE_APP_BUILD_TIME=""

# ===== Analytics — Yandex Metrika =====
# Числовой идентификатор счётчика из https://metrika.yandex.ru
# Если не задан — Метрика не загружается (graceful no-op)
VITE_YM_COUNTER_ID=

# ===== Analytics — Google Analytics 4 =====
# Measurement ID вида G-XXXXXXXXXX из https://analytics.google.com
# Если не задан — GA4 не загружается (graceful no-op)
VITE_GA_MEASUREMENT_ID=

# ===== Supabase (для Auth, TURN/WebRTC звонков, Storage) =====
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Prefer VITE_SUPABASE_PUBLISHABLE_KEY (anon key)
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
# Supabase Personal Access Token (для CLI / Edge Functions / Management API)
# Получить: https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN="sbp_YOUR_PERSONAL_ACCESS_TOKEN"

# ===== TURN / WebRTC (звонки за NAT) ==================================
# ===== Calls V2 / SFU / E2EE ==========================================
# Production-grade client path for calls. Without these vars the app can
# create a call row in DB but will not be able to bootstrap SFU media.
VITE_CALLS_V2_ENABLED="true"
# Single-region endpoint (optional if using the multi-region list below)
VITE_CALLS_V2_WS_URL=""
# Recommended multi-region setup for production failover
# Example: wss://sfu-ru.mansoni.com/ws,wss://sfu-tr.mansoni.com/ws,wss://sfu-ae.mansoni.com/ws
VITE_CALLS_V2_WS_URLS=""
# Periodic E2EE epoch rotation interval; do not set below 30000
VITE_CALLS_V2_REKEY_INTERVAL_MS="120000"
# Advertise Insertable Streams / SFrame capability when supported by the browser
VITE_CALLS_FRAME_E2EE_ADVERTISE_SFRAME="true"

# Supabase Edge Function `get-turn-credentials` генерирует HMAC-SHA1 credentials для coturn.
# Supabase Edge Function `get-turn-credentials` генерирует HMAC-SHA1 credentials для coturn.
# Shared secret ДОЛЖЕН совпадать с static-auth-secret в infra/calls/coturn/turnserver.prod.conf
# Сгенерировать: openssl rand -hex 32
# Установить в Supabase Dashboard → Settings → Vault → New secret: TURN_AUTH_SECRET
TURN_AUTH_SECRET=""

# Опциональный URL внешнего TURN credentials endpoint (если не используешь Supabase Edge Function).
# Если задан — webrtc-config.ts использует его вместо встроенной функции turn-credentials.
# Пример: https://your-api.example.com/get-turn-credentials
VITE_TURN_CREDENTIALS_URL=""

# Если TURN endpoint требует статический API-ключ (не нужно для Supabase Edge Function)
VITE_TURN_CREDENTIALS_API_KEY=""

# ===== Server-only secrets (never expose to client) =====
TURN_CREDENTIALS_API_KEY=""
DELEGATION_ISSUER_SECRET=""

# Comma-separated allowlist for browser origins in Edge Functions
# Example: https://mansoni.ru,https://www.mansoni.ru
CORS_ALLOWED_ORIGINS=""

# ===== ARIA AI Assistant =====
# Суpabase Edge Function secret (устанавливается в Supabase Dashboard → Settings → Vault)
# AI_API_KEY — ключ внешнего AI провайдера (если используешь api.mansoni.ru / OpenRouter)
# Если НЕ установлен → ARIA автоматически работает через встроенный TypeScript движок

# Для прямого вызова AI с фронтенда (опционально, если не хочешь Edge Function)
VITE_AI_API_KEY=""
# Endpoint AI (по умолчанию api.mansoni.ru)
VITE_AI_API_URL="https://api.mansoni.ru/v1/chat/completions"
# Модель AI (по умолчанию gemini-2.5-pro)
VITE_AI_MODEL="google/gemini-2.5-pro-exp-03-25"

# ===== ARIA Self-Hosted Python Backend =====
# Если запустил ai_engine/server/main.py локально или на сервере:
#   pip install -r ai_engine/server/requirements.txt
#   uvicorn ai_engine.server.main:app --host 0.0.0.0 --port 8000
#
# Supabase Edge Function secret (Vault):
#   ARIA_BACKEND_URL = http://YOUR_SERVER_IP:8000
#   ARIA_BACKEND_KEY = your-aria-api-key
#
# Локальная разработка: нужен supabase functions serve с --env-file
ARIA_BACKEND_URL=""
ARIA_BACKEND_KEY="local-dev-only-key"
# Optional: distributed feedback rate limiting for ARIA backend.
# If set, ai_engine.learning.feedback_store uses Redis INCR/EXPIRE bucket limiter.
ARIA_FEEDBACK_REDIS_URL="redis://localhost:6379/0"

# ===== Sentry Error Tracking =====
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# Если не задан — Sentry не загружается (graceful no-op)
VITE_SENTRY_DSN=
# Environment tag reported to Sentry (production | staging | development).
# По умолчанию: 'development' если import.meta.env.DEV, иначе 'production'
VITE_SENTRY_ENVIRONMENT=
# Release string (e.g. "1.2.3" or git SHA). Optional — улучшает source-map mapping.
VITE_SENTRY_RELEASE=
VITE_IMGLY_LICENSE_KEY=""

# ===== Analytics firehose (Redpanda ingest) =====
# Frontend endpoint that accepts batched events
VITE_ANALYTICS_INGEST_URL="https://analytics.mansoni.ru/analytics/events"

# ===== Analytics ingest service (server-only) =====
ANALYTICS_KAFKA_BROKERS="localhost:9092"
ANALYTICS_KAFKA_TOPIC="analytics.v1"
ANALYTICS_KAFKA_CLIENT_ID="mansoni-analytics-ingest"
ANALYTICS_INGEST_PORT="4010"
ANALYTICS_CORS_ORIGINS="https://mansoni.ru,https://www.mansoni.ru"
# Optional: require api key for ingest
ANALYTICS_INGEST_API_KEY=""

# ===== ClickHouse consumer =====
ANALYTICS_CH_URL="http://localhost:8123"
ANALYTICS_CH_DATABASE="analytics"
ANALYTICS_CH_USER="default"
ANALYTICS_CH_PASSWORD=""

# Optional (dev / seeding)
VITE_SEED_TEST_CHATS_TOKEN="CHANGE_ME"

# Optional (CI/CD chat schema probe hardening)
# Used by scripts/chat/schema-probe-ci.mjs when REQUIRE_CHAT_SCHEMA_PROBE=1.
SUPABASE_SERVICE_ROLE_KEY=""
VITE_EXPECTED_SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
CHAT_SCHEMA_EXPECTED_VERSION="2"

# ═══════════════════════════════════════════
# Email Router
# ═══════════════════════════════════════════
# Email sends are proxied through Supabase Edge Function (email-send).
# The API key NEVER reaches the browser — it lives only in Supabase Vault.
#
# Email Router — серверные переменные (НЕ ставить с префиксом VITE_!)
# Устанавливаются в Supabase Dashboard → Settings → Vault (Secrets):
# EMAIL_ROUTER_API_KEY=your-secret-key-min-16-chars  # Только в Supabase Vault!
# EMAIL_ROUTER_URL=http://email-router:8090           # Только в Supabase Vault!
#
# Email Router — клиентские переменные (только для локальной разработки)
# VITE_EMAIL_ROUTER_DIRECT=true  # Включить прямой режим (только dev!)
# VITE_EMAIL_ROUTER_API_URL=http://localhost:8090  # Только при VITE_EMAIL_ROUTER_DIRECT=true
# VITE_EMAIL_ROUTER_API_KEY=dev-test-key-1234567890  # Только при VITE_EMAIL_ROUTER_DIRECT=true
  
# 🎬 Media Server (AdminVPS) ════════════════════════════════════════════
# URL медиа-сервера на AdminVPS. Загрузка фото/видео/аудио идёт через него.
# В production: https://media.mansoni.ru
# В dev: http://localhost:3100
VITE_MEDIA_SERVER_URL=http://localhost:3100 

# ===== Livestream Gateway (LiveKit / SFU) ================================
# REST gateway for token generation, stream management, chat relay
# In production: https://live-gateway.yourdomain.com
# In dev: http://localhost:3100
VITE_LIVESTREAM_GATEWAY_URL=http://localhost:3100
# LiveKit WebSocket URL (public, used by client SDK)
# In production: wss://live.yourdomain.com
VITE_LIVEKIT_PUBLIC_URL=wss://live.yourdomain.com

# === Video Editor (CapCut-like) ===
# REST API для видеоредактора (проекты, таймлайн, рендер)
# В production: https://editor-api.yourdomain.com
# В dev: http://localhost:3002
VITE_EDITOR_API_URL=http://localhost:3002
