#!/usr/bin/env sh
set -eu

echo "[pre-commit] BOM guard"
node ./scripts/encoding/check-bom.mjs

echo "[pre-commit] E2EE critical guard"
node ./scripts/security/e2ee-critical-guard.mjs

echo "[pre-commit] Supabase db push policy guard"
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/supabase-db-push-policy-guard.ps1
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/supabase-db-push-policy-guard.ps1
else
  echo "  WARN: PowerShell not found, skipping Supabase db push policy guard"
fi
