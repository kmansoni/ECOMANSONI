{
  "name": "media-server",
  "version": "1.0.0",
  "description": "Media upload API for AdminVPS — MinIO S3 backend with image/video processing",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@fastify/multipart": "^8.3.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fastify": "^4.26.2",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^5.2.3",
    "pino": "^8.19.0",
    "sharp": "^0.33.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
