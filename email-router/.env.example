# ─── Email Router Configuration ───────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to version control.

# HTTP server port
EMAIL_ROUTER_PORT=8090

# API key for authenticating POST /send requests (min 32 chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ROUTER_API_KEY=change-me-to-a-random-secret-min-32-chars

# ─── SMTP relay ───────────────────────────────────────────────────────────────
#
# Production (Docker Compose with infra/mail/):
#   SMTP_HOST=mailserver   ← Docker container name (DNS resolves within network)
#   SMTP_USER=asset@mansoni.ru
#   SMTP_PASS=<password set via setup-mail.sh>
#
# Local dev (no Docker Compose):
#   SMTP_HOST=localhost
#   SMTP_PORT=1025         ← Mailhog or similar local SMTP trap
#   SMTP_USER=             ← Leave empty for Mailhog (no auth)
#   SMTP_PASS=

# Hostname of your Postfix / SMTP relay
# In Docker Compose: use container name "mailserver" (Docker DNS)
# In production standalone: use "mail.mansoni.ru"
SMTP_HOST=mailserver

# SMTP submission port (587 = STARTTLS, 465 = SMTPS/implicit TLS, 25 = plaintext)
SMTP_PORT=587

# SASL credentials — must match an account created via setup-mail.sh
# Service account: asset@mansoni.ru (created by setup-mail.sh)
SMTP_USER=asset@mansoni.ru
SMTP_PASS=your-smtp-password

# Default From address (used when "from" field is not supplied in the request)
SMTP_FROM=asset@mansoni.ru

# Set to "true" to use implicit TLS (SMTPS) on SMTP_PORT 465
# Leave empty/false for STARTTLS on port 587
SMTP_SECURE=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * to allow ALL origins (not recommended in production).
CORS_ORIGINS=https://mansoni.ru,https://www.mansoni.ru

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: debug | info | error
LOG_LEVEL=info

# ─── Mail domain (used in Message-ID generation) ──────────────────────────────
MAIL_DOMAIN=mansoni.ru
