      "feature_version": "rel_feat_v1",
      "normalization_version": "logistic_v1",
      "range": [0.0, 1.0],
      "fallback_value": 0.15,
      "weight": 0.24,
      "normalization": {
        "method": "logistic",
        "params": { "k": 4.2, "x0": 0.35 }
      }
    },
    {
      "name": "relevance",
      "scorer_version": "relv_v1",
      "feature_version": "relv_feat_v1",
      "normalization_version": "minmax_v1",
      "range": [0.0, 1.0],
      "fallback_value": 0.20,
      "weight": 0.17,
      "normalization": {
        "method": "minmax_clamped",
        "params": { "min": 0.0, "max": 1.0 }
      }
    },
    {
      "name": "freshness",
      "scorer_version": "fresh_v1",
      "feature_version": "fresh_feat_v1",
      "normalization_version": "piecewise_decay_v1",
      "range": [0.0, 1.0],
      "fallback_value": 0.10,
      "weight": 0.13,
      "normalization": {
        "method": "piecewise_decay",
        "params": {}
      }
    },
    {
      "name": "quality",
      "scorer_version": "qae_v1",
      "feature_version": "qae_feat_v1",
      "normalization_version": "logistic_v1",
      "range": [0.0, 1.0],
      "fallback_value": 0.25,
      "weight": 0.12,
      "normalization": {
        "method": "logistic",
        "params": { "k": 3.8, "x0": 0.45 }
      }
    },
    {
