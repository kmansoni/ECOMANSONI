      "range": [0.0, 1.0],
      "fallback_value": 0.30,
      "weight": 0.10,
      "normalization": {
        "method": "bucketed_lookup",
        "params": { "A": 1.0, "B": 0.82, "C": 0.50, "D": 0.10 }
      }
    },
    {
      "name": "conversation",
      "scorer_version": "conv_v1",
      "feature_version": "conv_feat_v1",
      "normalization_version": "logistic_v1",
      "range": [0.0, 1.0],
      "fallback_value": 0.10,
      "weight": 0.08,
      "normalization": {
        "method": "logistic",
        "params": { "k": 4.0, "x0": 0.25 }
