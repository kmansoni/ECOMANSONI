# ============================================================
# Media Server — Environment Variables
# Copy to .env and fill in all CHANGE_ME / YOUR_* values
# NEVER commit .env to version control
# ============================================================

# ----------------------------------------------------------
# MinIO — S3-compatible object storage
# ----------------------------------------------------------
MINIO_ROOT_USER=mansoni-media-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
MINIO_ENDPOINT=http://minio:9000

# ----------------------------------------------------------
# Media API (Node.js, port 3100)
# ----------------------------------------------------------
MEDIA_API_PORT=3100
MEDIA_DOMAIN=media.mansoni.ru

# Supabase — used for JWT verification and user lookups
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Must match SUPABASE_JWT_SECRET in your Supabase project settings
JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# ----------------------------------------------------------
# Nginx / TLS
# ----------------------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/media.mansoni.ru/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/media.mansoni.ru/privkey.pem

# ----------------------------------------------------------
# Upload size limits (in MB)
# ----------------------------------------------------------
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=50
MAX_AVATAR_SIZE_MB=5

# ----------------------------------------------------------
# Media processing parameters
# ----------------------------------------------------------
IMAGE_MAX_WIDTH=2048
IMAGE_QUALITY=85
VIDEO_MAX_BITRATE=4000k
THUMBNAIL_WIDTH=480
THUMBNAIL_HEIGHT=480

# ----------------------------------------------------------
# HLS Adaptive Bitrate Transcoding
# ----------------------------------------------------------
# Set TRANSCODE_ENABLED=false in dev/low-resource environments to skip HLS
# and fall back to storing the original video + thumbnail only.
TRANSCODE_ENABLED=true

# Isolated temp directory for HLS segment files during transcoding.
# Must be writable by the media-api process (user: media).
# Separate from TMP_DIR to allow independent cleanup policies.
TRANSCODE_TEMP_DIR=/tmp/media-transcode

# HLS chunk duration in seconds. 6s is the industry standard (Apple HLS spec).
# Shorter = lower TTFF (time to first frame) but more segments / MinIO PUTs.
# Do not set below 2s or above 10s without testing player compatibility.
HLS_SEGMENT_DURATION=6

# Maximum input video duration in seconds.
# Videos exceeding this limit are rejected with HTTP 422 before transcoding starts.
# Prevents runaway FFmpeg workers from exhausting CPU and disk on the pod.
# Default: 300 (5 minutes). Increase only if your use-case requires longer clips.
MAX_VIDEO_DURATION=300
