# =============================================================================
# ECOMANSONI Livestream Infrastructure — Environment Variables
# Copy to .env and fill in production values.
# NEVER commit .env to version control (it is in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit — Core media server credentials
# LIVEKIT_API_KEY / LIVEKIT_API_SECRET: used by gateway to mint room tokens
#   and control the LiveKit API. Rotate by adding new key pair to livekit.yaml
#   keys: section, deploying, waiting for token TTL to expire, then removing old.
# LIVEKIT_PUBLIC_URL: the WebSocket URL clients connect to (wss://).
#   Must be reachable from browser/mobile. Often behind nginx/CDN.
# LIVEKIT_WEBHOOK_HMAC_SECRET: must match the api_secret of the api_key used
#   in livekit.yaml webhook.api_key. Gateway validates HMAC-SHA256 signature.
# -----------------------------------------------------------------------------
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_change_me_in_production_min_32_chars
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_PUBLIC_URL=wss://live.yourdomain.com
LIVEKIT_WEBHOOK_HMAC_SECRET=secret_change_me_in_production_min_32_chars

# -----------------------------------------------------------------------------
# RTMP / WHIP Ingress ports (informational — used by nginx and docs)
# -----------------------------------------------------------------------------
LIVEKIT_INGRESS_RTMP_PORT=1935
LIVEKIT_INGRESS_WHIP_PORT=8080

# -----------------------------------------------------------------------------
# Redis — shared state bus for LiveKit cluster + gateway rate limiting
# Port 6381 to avoid collision with app Redis (6379) and nav Redis (6380).
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# MinIO — S3-compatible object storage for recordings, thumbnails, HLS
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD: MinIO admin credentials.
#   Must be ≥ 8 characters. Change before first boot; cannot be changed after
#   MinIO initialises without data migration.
# S3_ENDPOINT: internal URL from gateway → minio container.
#   For CDN delivery, presigned URLs are generated with public endpoint.
# S3_FORCE_PATH_STYLE: required for MinIO (not virtual-hosted buckets).
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me_in_production

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_change_me_in_production
S3_BUCKET_RECORDINGS=livestream-recordings
S3_BUCKET_THUMBNAILS=livestream-thumbnails
S3_BUCKET_HLS=livestream-hls
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Supabase — PostgreSQL + Auth + Realtime + Edge Functions
# SUPABASE_SERVICE_ROLE_KEY: full DB access — never expose to clients.
# SUPABASE_ANON_KEY: public key — safe for client-side use.
# SUPABASE_JWT_SECRET: used by gateway to verify user JWT tokens.
#   Must match the JWT secret configured in your Supabase project.
# -----------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------------------------
# Gateway — livestream-gateway Node.js service
# NODE_ENV: production | development
# LOG_LEVEL: fatal | error | warn | info | debug | trace
# -----------------------------------------------------------------------------
GATEWAY_PORT=3100
GATEWAY_HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CDN — used for serving HLS segments and thumbnails at scale
# CDN_URL: base URL of your CDN pull zone pointing to MinIO.
#   Example: https://cdn.yourdomain.com
# CDN_PULL_ZONE_ID: BunnyCDN/Cloudflare zone ID for cache purge on stream end.
# Leave empty to serve HLS directly from MinIO (not recommended for prod).
# -----------------------------------------------------------------------------
CDN_URL=https://cdn.yourdomain.com
CDN_PULL_ZONE_ID=

# -----------------------------------------------------------------------------
# Content Moderation
# NSFW_API_URL: internal URL of the screenshot-based NSFW classifier.
#   Set to empty to disable automated moderation (manual review only).
# NSFW_THRESHOLD: confidence threshold 0.0–1.0. Above this → auto-suspend.
# -----------------------------------------------------------------------------
NSFW_API_URL=http://nsfw-detector:5000
NSFW_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# TURN Server — co-located on LiveKit node (use dedicated coturn for scale)
# TURN_DOMAIN: public DNS name of the TURN server. Must match TLS cert CN/SAN.
# TURN_TLS_CERT_PATH / TURN_TLS_KEY_PATH: paths inside livekit-certs volume.
# -----------------------------------------------------------------------------
TURN_DOMAIN=turn.yourdomain.com
TURN_TLS_CERT_PATH=/etc/livekit/certs/turn.crt
TURN_TLS_KEY_PATH=/etc/livekit/certs/turn.key

# -----------------------------------------------------------------------------
# Notification Router — push notifications for "X went live" events
# Internal service URL. Leave empty if notification-router is on app-net.
# -----------------------------------------------------------------------------
NOTIFICATION_ROUTER_URL=http://notification-router:4000

# -----------------------------------------------------------------------------
# Grafana / Prometheus (optional observability)
# GRAFANA_USER / GRAFANA_PASSWORD: change before exposing Grafana dashboard.
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_in_production
