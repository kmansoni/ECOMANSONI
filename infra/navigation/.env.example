# =============================================================================
# ECOMANSONI Navigation Platform — Environment Variables
# Copy to .env and fill in secrets before running docker-compose up
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL / PostGIS (Martin tile server backend)
# In production: use managed Supabase/RDS endpoint, not the local db container
# -----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
# REQUIRED: set a strong password (min 32 chars, random)
POSTGRES_PASSWORD=changeme_in_production

# -----------------------------------------------------------------------------
# ClickHouse analytics
# Default user has empty password — lock down in production via users.xml
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# Grafana admin credentials
# REQUIRED: change before exposing port 3001 externally
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_in_production

# -----------------------------------------------------------------------------
# Valhalla routing engine
# tile_urls: Geofabrik PBF download URL; change region as needed
# Additional info: https://download.geofabrik.de/
# -----------------------------------------------------------------------------
VALHALLA_TILE_URLS=https://download.geofabrik.de/russia-latest.osm.pbf

# -----------------------------------------------------------------------------
# Redpanda / Kafka
# No auth in single-broker dev. In production enable SASL/SCRAM-SHA-256.
# -----------------------------------------------------------------------------
REDPANDA_BROKER_INTERNAL=redpanda:29092
REDPANDA_BROKER_EXTERNAL=localhost:9092

# -----------------------------------------------------------------------------
# Navigation API (external service that connects to this infra)
# Used by Prometheus scraping target — adjust host:port as needed
# -----------------------------------------------------------------------------
NAVIGATION_API_HOST=navigation-api
NAVIGATION_API_PORT=8000
NAVIGATION_API_METRICS_PATH=/metrics
