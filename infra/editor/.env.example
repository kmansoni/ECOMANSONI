# ═══════════════════════════════════════════
# Editor API — Environment Configuration
# ═══════════════════════════════════════════
# Copy to .env and fill in actual values.

# Editor API
EDITOR_API_PORT=3002

# PostgreSQL (shared with main app Supabase instance)
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# JWT (MUST match main app JWT_SECRET for auth interop)
JWT_SECRET=your-jwt-secret-at-least-32-chars-long

# MinIO / S3-compatible Object Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=
MEDIA_DOMAIN=http://localhost:9000

# Redis (render queue, caching)
REDIS_PORT=6380

# Worker — render pipeline configuration
RENDER_CONCURRENCY=2
RENDER_TIMEOUT_MS=1800000

# Logging
LOG_LEVEL=info
