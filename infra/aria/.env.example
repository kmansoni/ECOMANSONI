# ============================================================
# ARIA VPS Server — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ----------------------------------------------------------
# AI Provider (OpenAI-compatible)
# ----------------------------------------------------------
AI_API_KEY=YOUR_AI_API_KEY
AI_API_URL=https://api.mansoni.ru/v1/chat/completions
AI_DEFAULT_MODEL=google/gemini-2.5-pro-exp-03-25

# ----------------------------------------------------------
# Shared secret with Supabase Vault (ARIA_BACKEND_KEY)
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
ARIA_SERVER_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ----------------------------------------------------------
# Supabase (for memory storage via pgvector)
# ----------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=info
