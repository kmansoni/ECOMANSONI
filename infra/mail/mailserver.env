# ═══════════════════════════════════════════════════════════════════════════════
# docker-mailserver configuration
# https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
#
# This file is loaded by docker-compose.yml via env_file: mailserver.env
# Do NOT add secrets here — use .env for EMAIL_ROUTER_API_KEY, SMTP passwords.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── TLS ────────────────────────────────────────────────────────────────────
# Use Let's Encrypt certificates (mounted at /etc/letsencrypt/)
SSL_TYPE=letsencrypt

# TLS security level: modern (TLS 1.2+, strong ciphers only)
TLS_LEVEL=intermediate

# ─── DKIM ───────────────────────────────────────────────────────────────────
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1

# DKIM key size (2048 recommended, 4096 for maximum security)
OPENDKIM_KEY_LENGTH=2048

# ─── Anti-spam ──────────────────────────────────────────────────────────────
ENABLE_SPAMASSASSIN=1

# Move spam to Junk folder instead of rejecting (better UX)
SPAMASSASSIN_SPAM_TO_INBOX=1

# Spam score threshold: messages above this score go to Junk
SA_SPAM_SUBJECT=***SPAM***
SA_TAG=2.0
SA_TAG2=6.31
SA_KILL=10.0

# ─── Fail2ban ───────────────────────────────────────────────────────────────
ENABLE_FAIL2BAN=1

# Ban duration in seconds (1 hour)
FAIL2BAN_BANTIME=3600

# Max retries before ban
FAIL2BAN_MAXRETRY=5

# ─── ClamAV (antivirus) ─────────────────────────────────────────────────────
# Disabled to save RAM on small VPS (2GB). Enable if RAM >= 4GB.
ENABLE_CLAMAV=0

# ─── Greylisting ────────────────────────────────────────────────────────────
# Disabled for faster delivery. Enable if spam is a problem.
ENABLE_POSTGREY=0

# ─── Dovecot (IMAP) ─────────────────────────────────────────────────────────
# Enable IMAP so users can read mail via email clients
SMTP_ONLY=0

# ─── Quotas ─────────────────────────────────────────────────────────────────
ENABLE_QUOTAS=1

# Default mailbox quota (0 = unlimited, set per-user via setup.sh)
POSTFIX_MAILBOX_SIZE_LIMIT=0

# ─── Message size ───────────────────────────────────────────────────────────
# 50 MB max message size
POSTFIX_MESSAGE_SIZE_LIMIT=52428800

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Network ────────────────────────────────────────────────────────────────
# Permit relay from Docker internal network (email-router container)
# Docker bridge network default: 172.16.0.0/12
PERMIT_DOCKER=network

# ─── SASL ───────────────────────────────────────────────────────────────────
ENABLE_SASLAUTHD=0

# ─── SRS (Sender Rewriting Scheme) ─────────────────────────────────────────
# Rewrite sender address for forwarded mail to pass SPF checks
ENABLE_SRS=1

# ─── Postscreen ─────────────────────────────────────────────────────────────
# Lightweight pre-filter for inbound SMTP connections
ENABLE_POSTSCREEN=1

# ─── RBL (Real-time Blackhole Lists) ────────────────────────────────────────
# Block known spam sources
POSTSCREEN_ACTION=enforce

# ─── DNSBL ──────────────────────────────────────────────────────────────────
# Reject mail from IPs in Spamhaus ZEN blacklist
ENABLE_DNSBL=1

# ─── Amavis ─────────────────────────────────────────────────────────────────
ENABLE_AMAVIS=0

# ─── Fetchmail ──────────────────────────────────────────────────────────────
ENABLE_FETCHMAIL=0

# ─── Managesieve ────────────────────────────────────────────────────────────
# Allow users to manage server-side mail filters
ENABLE_MANAGESIEVE=1
