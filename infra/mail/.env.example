# ═══════════════════════════════════════════════════════════════════════════════
# Mansoni Mail Server — Environment Variables
#
# Copy to .env and fill in real values:
#   cp .env.example .env && nano .env
#
# SECURITY: Never commit .env to git. It is in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── email-router API Key ───────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
#   openssl rand -hex 32
EMAIL_ROUTER_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ─── SMTP account for email-router ─────────────────────────────────────────
# This is the mailbox that email-router authenticates as when sending mail.
# Must match an account created via: ./setup-mail.sh email add asset@mansoni.ru
SMTP_ASSET_USER=asset@mansoni.ru
SMTP_ASSET_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS

# ─── CORS origins for email-router ─────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production: only your frontend domains.
CORS_ORIGINS=https://mansoni.ru,https://www.mansoni.ru

# ─── Log level ──────────────────────────────────────────────────────────────
# Options: debug, info, error
LOG_LEVEL=info
