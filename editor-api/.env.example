# Server
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Auth (shared with media-server and main app)
JWT_SECRET=your-supabase-jwt-secret-here
SUPABASE_URL=https://your-project.supabase.co

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# MinIO / S3
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=mansoni

# Media domain for URL generation
MEDIA_DOMAIN=media.mansoni.ru

# Limits
MAX_PROJECTS_PER_USER=100
MAX_TRACKS_PER_PROJECT=20
MAX_CLIPS_PER_TRACK=200

# Render queue
RENDER_QUEUE_NAME=editor-render
